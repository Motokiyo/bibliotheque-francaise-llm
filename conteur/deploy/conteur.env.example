# Copy to /etc/conteur/conteur.env and fill on the server.
# Never commit a real env file.

OPENAI_API_KEY=

# Realtime model and voice used by the current book reader.
MODEL=gpt-realtime
VOICE=cedar

# Keep Uvicorn private behind Nginx.
CONTEUR_HOST=127.0.0.1
CONTEUR_PORT=7860

# Optional: set to production for operational clarity.
ENVIRONMENT=production

# Production WebSocket origin allowlist. Keep the public domain only in prod.
CONTEUR_ALLOWED_ORIGINS=https://conteur.eiffelai.io

# Keep Reachy/robot control disabled on the VPS unless explicitly needed.
CONTEUR_ENABLE_ROBOT=0

# The book reader uses OpenAI Realtime Cedar. Keep legacy HTTP TTS off in prod.
CONTEUR_ENABLE_TTS_ENDPOINT=0

# Live Bucéphale mirror, synced from /root/vault by conteur-bucephale-sync.timer.
CONTEUR_BUCEPHALE_DIR=/srv/conteur/live/chroniques-de-bucephale
